# Local dev config. Copy to `.env` (gitignored); the devshell auto-sources it.
#
#   cp .env.example .env
#
# Per-chain WebSocket RPC endpoints. These may contain API keys, so `.env` is
# gitignored — keep your real keys out of version control.
export BASE_WSS_URL="wss://base-mainnet.g.alchemy.com/v2/<YOUR_KEY>"
# export BSC_WSS_URL="wss://<your-bsc-endpoint>/<YOUR_KEY>"
# export TRON_WSS_URL="wss://<your-tron-endpoint>/<YOUR_KEY>"

# Keyless public endpoints work too (no secret):
# export BASE_WSS_URL="wss://base-rpc.publicnode.com"
# export BSC_WSS_URL="wss://bsc-rpc.publicnode.com"

# Optional: Flashblocks WS endpoint for the Base dual-stream path.
# export BASE_FLASHBLOCKS_WSS_URL="wss://..."

# NOTE: pools are NOT configured via env. They live in the config books
# (config/<chain>.official.toml / .secondary.toml) and are maintained by
# `arb scan`. Env vars are only for RPC endpoints + secrets.
